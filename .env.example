# Copy to backend/.env (or export in your shell) for local backend dev.
# NEVER commit the real values. The Android client never sees any of these.

# --- Anthropic / Claude (server-side ONLY) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-8

# --- MySQL ---
MYSQL_DSN=fitcoach:fitcoach@tcp(127.0.0.1:3306)/fitcoach?parseTime=true&loc=UTC

# --- HTTP server ---
HTTP_ADDR=:8080
LOG_LEVEL=info

# --- Auth ---
JWT_SIGNING_KEY=change-me-in-prod-min-32-bytes-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
